REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_001A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7ESTE CARGUEIRO ESTÁ REPLETO DE MÍSSEIS DE CRUZEIRO HIPERSÔNICOS DONG-FENG. COMPATÍVEL COM MACH 7. UM ATAQUE PODERIA DESTRUIR QUALQUER UM DOS NOSSOS PORTA-AVIÕES, INCLUINDO O OBAMA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_002A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7OS MÍSSEIS SERÃO ENTREGUES A ESSES DESTRÓIERES, REVESTIDOS COM NANOTUBOS DE CARBONO, TORNANDO-OS INVISÍVEIS PARA NOSSOS SATÉLITES. É POR ISSO QUE HARPER TEVE QUE FAZER ESSA FILMAGEM À MODA ANTIGA! A SDC PLANEIA LANÇAR ESTES MÍSSEIS CONTRA O IRÃO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_003A_BRIG_M
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7ISSO MESMO, RAPAZES, IRÃ. AGORA, JÁ TENHO PROBLEMAS SUFICIENTES. NÃO PRECISO QUE A PÉRSIA SEJA A CABRA DA SDC."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_003A_BRIG_S
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7ISSO MESMO, RAPAZES, IRÃ. JÁ TEMOS PROBLEMAS SUFICIENTES, ENTÃO NÃO PRECISO QUE A PÉRSIA SEJA AMIGA DO SDC."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_004A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7A DEFESA PRIMÁRIA DO TERMINAL KEPPEL É UM ÚNICO MÍSSIL DONG FENG, LOCALIZADO NO CENTRO CENTRAL."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_005A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7VOCÊ ESTARÁ EQUIPADO COM EXPLOSIVOS HPM. EXPLOSÕES DE MICROONDAS DE ALTA POTÊNCIA PARA EMBARALHAR O SISTEMA DE ORIENTAÇÃO DO MÍSSIL."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_006A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7O PERÍMETRO LESTE E OESTE É FLANQUEADO POR LASERS DE ELÉTRONS LIVRES, FEIXES SOBRECARREGADOS CAPAZES DE DESTRUIR QUALQUER MÍSSIL DE CURTO ALCANCE. PRECISAMOS DELES PARA DESTRUIR O CARGUEIRO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_007A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7SEUS MÓDULOS DE HACKERS PORTÁTEIS REPROGRAMARÃO SEUS SISTEMAS DE MIRA PARA FRITÁ-LOS EM SEU PRÓPRIO SUCO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_01_008A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7QUANDO AS DEFESAS DELES CAEM, VOCÊ CHAMA O KRAKEN E NÓS ATACAMOS O CARGUEIRO POR VIA AÉREA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_001A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7ALMIRANTE NO CONVÉS!"

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_002A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7OBRIGADO, COMANDANTE MASON."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_003A_BRIG_M
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7CONFIRA ESTA BELEZA. “PRESIDENTE” TIAN ZHAO, LÍDER DAS FORÇAS ARMADAS DA CHINA. O CHEFE DAS FORÇAS ARMADAS DA COLIGAÇÃO SDC. O DESGRAÇADO JOGA DURO, MESMO COM O GOVERNO DA CHINA. ELES TÊM TANTO CONTROLE SOBRE ELE QUANTO NÓS. ESTE GATO ANDA SOZINHO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_003A_BRIG_S
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7CONFIRA ESTA BELEZA. “PRESIDENTE” TIAN ZHAO, LÍDER DAS FORÇAS ARMADAS DA CHINA. O CHEFE DAS FORÇAS ARMADAS DA COLIGAÇÃO SDC. ELE JOGA DURO, MESMO COM O GOVERNO DA CHINA. ELES TÊM TANTO CONTROLE SOBRE ELE QUANTO NÓS. ESTE GATO ANDA SOZINHO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_004A_BRIG_M
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7O PRESIDENTE ZHAO ESTÁ APERTANDO AS BOLAS DA RÚSSIA, COM MUITA FORÇA. COMANDANTE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_004A_BRIG_S
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7O PRESIDENTE ZHAO ESTÁ APERTANDO A RÚSSIA, COM MUITA FORÇA. COMANDANTE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_005A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7SE A RÚSSIA CEDESSE E SE JUNTASSE AO SDC, ELES SERIAM A MAIOR FORÇA MILITAR DO PLANETA. O QUE É PRECISAMENTE O QUE MENENDEZ QUER, CRIAR SUPERPODERES PARA SE EXTERMINAREM MUTUAMENTE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_006A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7NESTE MOMENTO, O IRÃ E A ÍNDIA ESTÃO AMBOS SOB AMEAÇA. A SDC ESTÁ A AGIR. É HORA DO JSOC AVANÇAR."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_007A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7ESSES DESTRÓIERES DA CLASSE SOVREMENNIY SÃO REVESTIDOS COM NANOTUBOS DE CARBONO, TORNANDO-OS INVISÍVEIS PARA NOSSOS SATÉLITES. ENTÃO HARPER FEZ ESSA FILMAGEM À MODA ANTIGA!"

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_008A_HARP_M
LANG_SPANISH        "^1HARPER:^7SEÇÃO SEM MERDA. NADEI UM POUCO PERTO DEMAIS DOS TUBARÕES NAQUELE DIA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_008A_HARP_S
LANG_SPANISH        "^1HARPER:^7SEÇÃO SEM BRINCADEIRA. NADEI UM POUCO PERTO DEMAIS DOS TUBARÕES NAQUELE DIA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_009A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7ESSES TUBARÕES CARREGAM ASATS..."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_010A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7...E ESTAMOS, NESTE MOMENTO, CRUZANDO O MAR ARÁBICO COM FOGO SUFICIENTE PARA QUEIMAR METADE DOS SATÉLITES DO MUNDO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_011A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7O FOB SPECTRE É VITAL PARA PROTEGER A FRONTEIRA NORTE DA ÍNDIA. PARA UMA RESPOSTA RÁPIDA, NOSSA ÚNICA OPÇÃO É ENTRAR COM HALO."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_012A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7UMA VEZ NO CONVÉS, SEU OBJETIVO PRINCIPAL É DESATIVAR O PORTA-AVIÕES."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_013A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7ELES CONTROLAM TODOS OS SEUS SISTEMAS DE DEFESA AUTOMATIZADOS NESTA ÁREA. VOCÊ COMANDARÁ SEUS ASDS E, EM SEGUIDA, DESTRUIRÁ OS MOTORES E SISTEMAS DE ENERGIA DA NAVE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_014A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7AGORA, COMO O ALMIRANTE INDICOU, NÃO PODEMOS COLOCAR NOSSOS PRÓPRIOS JATOS NO ESPAÇO AÉREO DELES, ENTÃO... TEREMOS QUE USAR OS DELES."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_015A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7VOCÊ VOA COM ESSES VTOLS DIRETO DA CABINE DE COMANDO. ACABAR COM TODA A FROTA. ESTOU CLARO?"

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_019A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7O OBJETIVO PRINCIPAL DO INIMIGO SERÁ DESTRUIR A REDE DE DEFESA VISANDO GERADORES DE ENERGIA E UPLINKS DE SATÉLITE. SE A REDE CAIR, NÃO HÁ NADA QUE OS IMPEÇA DE PENETRAR NA SALA DE CONTROLE PRINCIPAL."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_02_020A_SECT_D
LANG_SPANISH        "^1SEÇÃO:^7SE ISSO ACONTECER, O FOB SPECTRE ESTARÁ FORA DO AR E SERÁ TEMPORADA DE CAÇA À ÍNDIA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_001A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7TENENTE COMANDANTE MASON, APRESENTE-SE NA SALA DE GUERRA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_002A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7MASON, ESTAMOS ESPERANDO POR VOCÊ NA SALA DE GUERRA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_003A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7TENENTE COMANDANTE MASON, APRESENTE-SE NA SALA DE GUERRA AGORA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_004A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7SUA EQUIPE ESTÁ PREPARADA E PRONTA PARA O BRIEFING, MASON."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_005A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7PARE DE PERDER TEMPO, MASON. VÁ PARA A SALA DE GUERRA IMEDIATAMENTE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_006A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7REPORTE-SE À SALA DE GUERRA AGORA, COMANDANTE. ISSO É UMA ORDEM."

