LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7O QUE FOI ISSO, MASON? ESPERO MELHOR DE VOCÊ."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_015A_BRIG_M
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7NUNCA VI UMA EXECUÇÃO DE MISSÃO TÃO LAMENTÁVEL. CONTROLE SUAS COISAS, MASON."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_015A_BRIG_S
