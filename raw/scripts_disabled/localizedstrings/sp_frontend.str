LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7MASON! PARE DE BRINCAR E VÁ PARA A SALA DE GUERRA."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_008A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7BOM TRABALHO, MASON."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_009A_BRIG_D
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7EU SABIA QUE PODERIA CONFIAR EM VOCÊ, COMANDANTE."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_010A_BRIG_M
