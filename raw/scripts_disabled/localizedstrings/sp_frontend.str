REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_016A_BRIG_M
LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7ISSO FOI UM FRACASSO EM GRANDE ESCALA EM TODOS OS ASPECTOS."

