LANG_SPANISH        "^1ALMIRANTE BRIGGS:^7FALAREMOS SOBRE ESSE FIASCO MAIS TARDE, MASON."

REFERENCE           FRONTEND_VOX_VOX_SFF_1_03_019A_BRIG_M
