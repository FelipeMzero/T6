LANG_SPANISH        "^1Reznov:^7Kravchenko."

REFERENCE           AFGHANISTAN_VOX_VOX_AFG_4_09_002A_REZN_D
LANG_SPANISH        "^1Reznov:^7Deve morrer."

REFERENCE           AFGHANISTAN_VOX_VOX_AFG_4_09_004A_WOOD_M
LANG_SPANISH        "^1Woods:^7Vendo aqueles malditos números de novo?!"

